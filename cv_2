_SIZE, IMG_SIZE))\n","\n","    img_array = np.array(image) / 255.0\n","    img_array = np.expand_dims(img_array, axis=0)\n","\n","    return img_array"]},{"cell_type":"code","execution_count":5,"metadata":{"id":"aZDmfLzkrX5Z","executionInfo":{"status":"ok","timestamp":1776330684061,"user_tz":-330,"elapsed":8,"user":{"displayName":"Suman Mondal","userId":"15873441841467413168"}}},"outputs":[],"source":["def predict_disease(image):\n","    \"\"\"\n","    Runs inference and returns structured results.\n","    - Top prediction must cross CONFIDENCE_THRESHOLD to be 'certain'\n","    - Returns top 3 predictions with full disease info from JSON\n","    \"\"\"\n","\n","    img = preprocess_image(image)\n","    predictions = model.predict(img, verbose=0)[0]\n","    top_confidence = predictions.max()\n","\n","\n","    if top_confidence < CONFIDENCE_THRESHOLD:\n","        return {\n","            \"status\": \"uncertain\",\n","            \"message\": f\" Model is not confident enough (best: {round(top_confidence*100, 1)}%). \"\n","                       f\"Please upload a clearer, well-lit leaf image.\",\n","            \"results\": []\n","        }\n","\n","\n","    top3_indices = predictions.argsort()[-3:][::-1]\n","\n","    results = []\n","    for idx in top3_indices:\n","        key = class_keys[idx]\n","        info = class_info[key]\n","        confidence = float(predictions[idx])\n","\n","        results.append({\n","            \"class_key\"  : key,\n","            \"plant\"      : info[\"plant\"],\n","            \"disease\"    : info[\"disease\"],\n","            \"confidence\" : round(confidence * 100, 2),\n","            \"reasons\"    : info[\"reasons\"],\n","            \"solutions\"  : info[\"solutions\"]\n","        })\n","\n","    return {\n","        \"status\": \"success\",\n","        \"results\": results\n","    }"]},{"cell_type":"code","execution_count":6,"metadata":{"id":"JdWwvVtkraqu","colab":{"base_uri":"https://localhost:8080/","height":628},"output